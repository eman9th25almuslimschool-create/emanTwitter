/**
 * Convert raw tweet text → HTML with formatted hashtags/mentions
 * @param {string} text
 * @returns {string}
 */
function formatText(text) {
  return text
    .replace(/\n/g, '<br>')
    .replace(/#(\w+)/g,  '<span class="htag">#$1</span>')
    .replace(/@(\w+)/g,  '<span class="mtag">@$1</span>');
}

/**
 * Build an avatar element style string
 * @param {number} ci - color index
 * @returns {{ bg: string, fg: string }}
 */
function avatarStyle(ci) {
  return {
    bg: AVATAR_COLORS[ci % AVATAR_COLORS.length],
    fg: AVATAR_TEXT[ci  % AVATAR_TEXT.length],
  };
}

