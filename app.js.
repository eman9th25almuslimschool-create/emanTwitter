/**
 * Toggle like state on a tweet
 * @param {number} id
 */
function handleLike(id) {
  const tweet = tweets.find(t => t.id === id);
  if (!tweet) return;

  tweet.liked  = !tweet.liked;
  tweet.likes += tweet.liked ? 1 : -1;

  refreshAll();
  if (tweet.liked) showToast('Pasand kiya ♥');
}

/**
 * Increment retweet count
 * @param {number} id
 */
function handleRT(id) {
  const tweet = tweets.find(t => t.id === id);
  if (!tweet) return;

  tweet.rts++;
  refreshAll();
  showToast('Retweet ho gaya ⟳');
}

/** Re-render both feed and profile tweet lists */
function refreshAll() {
  renderTweets(tweets, 'feedList');
  renderProfileTweets();
}

