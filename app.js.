    fg: AVATAR_TEXT[ci  % AVATAR_TEXT.length],
  };
}

// ──────────────────────────────────────────────────────
// RENDER — TWEETS
// ──────────────────────────────────────────────────────

/**
 * Render a list of tweet objects into a container element
 * @param {Array}  list        - tweet objects
 * @param {string} containerId - DOM id
 */
function renderTweets(list, containerId) {
  const el = document.getElementById(containerId);
  if (!el) return;

  if (!list.length) {
    el.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">⬡</div>
        <div class="empty-title">KHAMOSHI HAI</div>
        <div class="empty-sub">Abhi koi tweet nahi — pehle tweet likhein!</div>
      </div>`;
    return;
  }

  el.innerHTML = list.map((t, i) => {
    const av = avatarStyle(t.ci);
    return `
      <article class="tweet-card" style="animation-delay:${Math.min(i * 0.055, 0.44)}s">

        <div class="tw-avatar${t.verified ? ' vfy' : ''}"
          style="background:${av.bg};color:${av.fg}">${t.av}</div>

        <div class="tw-body">
          <div class="tw-meta">
            <span class="tw-name">${t.name}</span>
            <span class="tw-handle">@${t.handle}</span>
            <span class="tw-dot">·</span>
            <span class="tw-time">${t.time}</span>
          </div>

          <div class="tw-text">${formatText(t.text)}</div>

          ${t.img ? `<div class="tw-img">${t.img}</div>` : ''}

          <div class="tw-actions">
            <div class="tw-act reply" onclick="event.stopPropagation(); showToast('Reply — jald aa raha hai ⟳')">
              <span class="act-icon">💬</span> ${t.replies}
            </div>
            <div class="tw-act rt" onclick="event.stopPropagation(); handleRT(${t.id})">
              <span class="act-icon">⟳</span> ${t.rts}
            </div>
            <div class="tw-act like${t.liked ? ' liked' : ''}"
              onclick="event.stopPropagation(); handleLike(${t.id})">
              <span class="act-icon">${t.liked ? '♥' : '♡'}</span> ${t.likes}
            </div>
            <div class="tw-act" onclick="event.stopPropagation(); showToast('Link copy ho gaya! ◈')">
              <span class="act-icon">↗</span>
            </div>
          </div>
        </div>

      </article>`;
  }).join('');
}

// ──────────────────────────────────────────────────────
// INTERACTIONS — LIKE / RETWEET
// ──────────────────────────────────────────────────────

/**
 * Toggle like state on a tweet
 * @param {number} id
 */
function handleLike(id) {
  const tweet = tweets.find(t => t.id === id);
  if (!tweet) return;

  tweet.liked  = !tweet.liked;
  tweet.likes += tweet.liked ? 1 : -1;

  refreshAll();
  if (tweet.liked) showToast('Pasand kiya ♥');
}

/**
 * Increment retweet count
 * @param {number} id
 */
function handleRT(id) {
  const tweet = tweets.find(t => t.id === id);
  if (!tweet) return;

  tweet.rts++;
  refreshAll();
  showToast('Retweet ho gaya ⟳');
}

/** Re-render both feed and profile tweet lists */
function refreshAll() {
  renderTweets(tweets, 'feedList');
  renderProfileTweets();
}

// ──────────────────────────────────────────────────────
// COMPOSE
// ──────────────────────────────────────────────────────

/**
 * Update character counter ring and enable/disable send button
 * @param {string} inputId   - textarea element id
 * @param {string} counterId - counter span id
 * @param {string} btnId     - send button id
 */
function handleCompose(inputId, counterId, btnId) {
  const val    = document.getElementById(inputId).value;
  const used   = val.length;
  const rem    = MAX_CHARS - used;
  const pct    = used / MAX_CHARS;

  // Counter text
  const cntEl  = document.getElementById(counterId);
  cntEl.textContent = rem < 40 ? rem : '';
  cntEl.className   = 'ring-num' + (rem < 20 ? ' over' : rem < 50 ? ' warn' : '');

  // SVG ring (prefix "feed" or "modal")
  const prefix    = inputId === 'feedInput' ? 'feed' : 'modal';
  const circleEl  = document.getElementById(prefix + 'RingCircle');
  if (circleEl) {
    const offset = CIRCUMFERENCE * (1 - pct);
    circleEl.style.strokeDashoffset = offset;
    circleEl.className = 'ring-fg' + (rem < 20 ? ' over' : rem < 50 ? ' warn' : '');
  }

  // Send button
  document.getElementById(btnId).disabled = !val.trim();
}

/** Post tweet from inline feed compose */
function postFromFeed() {
  const val = document.getElementById('feedInput').value.trim();
  if (!val) return;

  createTweet(val);

  document.getElementById('feedInput').value = '';
  handleCompose('feedInput', 'feedCounter', 'feedSendBtn');
}

/** Post tweet from modal compose */
function postFromModal() {
  const val = document.getElementById('modalInput').value.trim();
  if (!val) return;

  createTweet(val);

  document.getElementById('modalInput').value = '';
  handleCompose('modalInput', 'modalCounter', 'modalSendBtn');
  closeModal();
}

/**
 * Create a new tweet object and prepend to feed
 * @param {string} text - tweet content
 */
function createTweet(text) {
  const tweet = {
    id:       nextId++,
    name:     'Ahmad Ali',
    handle:   'ahmad_ali',
    av:       'ع',
    ci:       0,
    verified: true,
    text,
    time:     'Abhi',
    likes:    0,
    liked:    false,
    rts:      0,
    replies:  0,
    img:      null,
    own:      true,
  };

  tweets.unshift(tweet);
  myTweets.unshift(tweet);

  refreshAll();
  updateProfileStats();
  showToast('Tweet live ho gaya! ⬡');
}

