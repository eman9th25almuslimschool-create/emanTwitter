/**
 * Render a list of tweet objects into a container element
 * @param {Array}  list        - tweet objects
 * @param {string} containerId - DOM id
 */
function renderTweets(list, containerId) {
  const el = document.getElementById(containerId);
  if (!el) return;

  if (!list.length) {
    el.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">⬡</div>
        <div class="empty-title">KHAMOSHI HAI</div>
        <div class="empty-sub">Abhi koi tweet nahi — pehle tweet likhein!</div>
      </div>`;
    return;
  }

  el.innerHTML = list.map((t, i) => {
    const av = avatarStyle(t.ci);
    return `
      <article class="tweet-card" style="animation-delay:${Math.min(i * 0.055, 0.44)}s">

        <div class="tw-avatar${t.verified ? ' vfy' : ''}"
          style="background:${av.bg};color:${av.fg}">${t.av}</div>

        <div class="tw-body">
          <div class="tw-meta">
            <span class="tw-name">${t.name}</span>
            <span class="tw-handle">@${t.handle}</span>
            <span class="tw-dot">·</span>
            <span class="tw-time">${t.time}</span>
          </div>

          <div class="tw-text">${formatText(t.text)}</div>

          ${t.img ? `<div class="tw-img">${t.img}</div>` : ''}

          <div class="tw-actions">
            <div class="tw-act reply" onclick="event.stopPropagation(); showToast('Reply — jald aa raha hai ⟳')">
              <span class="act-icon">💬</span> ${t.replies}
            </div>
            <div class="tw-act rt" onclick="event.stopPropagation(); handleRT(${t.id})">
              <span class="act-icon">⟳</span> ${t.rts}
            </div>
            <div class="tw-act like${t.liked ? ' liked' : ''}"
              onclick="event.stopPropagation(); handleLike(${t.id})">
              <span class="act-icon">${t.liked ? '♥' : '♡'}</span> ${t.likes}
            </div>
            <div class="tw-act" onclick="event.stopPropagation(); showToast('Link copy ho gaya! ◈')">
              <span class="act-icon">↗</span>
            </div>
          </div>
        </div>

      </article>`;
  }).join('');
}

