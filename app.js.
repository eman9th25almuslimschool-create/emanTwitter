/** Render follow suggestions */
function renderWho() {
  document.getElementById('whoList').innerHTML = suggestions.map((s, i) => {
    const av = avatarStyle(s.ci);
    return `
      <div class="who-row">
        <div class="who-av" style="background:${av.bg};color:${av.fg}">${s.av}</div>
        <div class="who-info">
          <div class="who-name">${s.name}</div>
          <div class="who-handle">@${s.handle}</div>
        </div>
        <button class="follow-btn${s.following ? ' following' : ''}" onclick="toggleFollow(${i})">
          ${s.following ? 'FOLLOWING' : 'FOLLOW'}
        </button>
      </div>`;
  }).join('');
}

/**
 * Toggle follow/unfollow
 * @param {number} i - index in suggestions array
 */
function toggleFollow(i) {
  suggestions[i].following = !suggestions[i].following;
  renderWho();
  showToast(
    suggestions[i].following
      ? `@${suggestions[i].handle} ko follow kiya ✓`
      : 'Unfollow ho gaya'
  );
}

