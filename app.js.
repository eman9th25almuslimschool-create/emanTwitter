/**
 * Update character counter ring and enable/disable send button
 * @param {string} inputId   - textarea element id
 * @param {string} counterId - counter span id
 * @param {string} btnId     - send button id
 */
function handleCompose(inputId, counterId, btnId) {
  const val    = document.getElementById(inputId).value;
  const used   = val.length;
  const rem    = MAX_CHARS - used;
  const pct    = used / MAX_CHARS;

  // Counter text
  const cntEl  = document.getElementById(counterId);
  cntEl.textContent = rem < 40 ? rem : '';
  cntEl.className   = 'ring-num' + (rem < 20 ? ' over' : rem < 50 ? ' warn' : '');

  // SVG ring (prefix "feed" or "modal")
  const prefix    = inputId === 'feedInput' ? 'feed' : 'modal';
  const circleEl  = document.getElementById(prefix + 'RingCircle');
  if (circleEl) {
    const offset = CIRCUMFERENCE * (1 - pct);
    circleEl.style.strokeDashoffset = offset;
    circleEl.className = 'ring-fg' + (rem < 20 ? ' over' : rem < 50 ? ' warn' : '');
  }

  // Send button
  document.getElementById(btnId).disabled = !val.trim();
}

/** Post tweet from inline feed compose */
function postFromFeed() {
  const val = document.getElementById('feedInput').value.trim();
  if (!val) return;

  createTweet(val);

  document.getElementById('feedInput').value = '';
  handleCompose('feedInput', 'feedCounter', 'feedSendBtn');
}

/** Post tweet from modal compose */
function postFromModal() {
  const val = document.getElementById('modalInput').value.trim();
  if (!val) return;

  createTweet(val);

  document.getElementById('modalInput').value = '';
  handleCompose('modalInput', 'modalCounter', 'modalSendBtn');
  closeModal();
}

/**
 * Create a new tweet object and prepend to feed
 * @param {string} text - tweet content
 */
function createTweet(text) {
  const tweet = {
    id:       nextId++,
    name:     'Ahmad Ali',
    handle:   'ahmad_ali',
    av:       'ع',
    ci:       0,
    verified: true,
    text,
    time:     'Abhi',
    likes:    0,
    liked:    false,
    rts:      0,
    replies:  0,
    img:      null,
    own:      true,
  };

  tweets.unshift(tweet);
  myTweets.unshift(tweet);

  refreshAll();
  updateProfileStats();
  showToast('Tweet live ho gaya! ⬡');
}

